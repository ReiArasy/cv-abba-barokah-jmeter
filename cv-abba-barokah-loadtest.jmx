            <stringProp name="Header.value">en-US,en;q=0.9,id;q=0.8</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>
      <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert HTTP 200 OK or 302 Redirect" enabled="true">
        <collectionProp name="Asserion.test_strings">
          <stringProp name="1205315842">200|302</stringProp>
        </collectionProp>
        <stringProp name="Assertion.custom_message">Respons Server bukan HTTP 200 OK atau 302 Redirect</stringProp>
        <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
        <boolProp name="Assertion.assume_success">false</boolProp>
        <intProp name="Assertion.test_type">2</intProp>
      </ResponseAssertion>
